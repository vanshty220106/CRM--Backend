NODE_ENV=development
PORT=5001

# MongoDB Atlas URI — leave blank to use local file storage fallback
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/crm_db?retryWrites=true&w=majority&appName=Cluster0

# JWT
JWT_SECRET=your_strong_random_secret_here
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS — set to your frontend origin
CORS_ORIGIN=http://localhost:5173
